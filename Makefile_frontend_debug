.PHONY: help generateDebugJsSourceMap

PYTHON ?= python3
PROJECT ?= $(CURDIR)
PROJECT_DIR = $(abspath $(PROJECT))

define Z8_DEBUG_SOURCEMAPS_GRADLE_B64

endef
export Z8_DEBUG_SOURCEMAPS_GRADLE_B64

define Z8_DEBUG_SOURCEMAPS_TOGGLE_PY_B64

endef
export Z8_DEBUG_SOURCEMAPS_TOGGLE_PY_B64

define Z8_DEBUG_SOURCEMAPS_RUNNER_PY
from __future__ import annotations
import base64, os, shutil, stat, subprocess, sys
from pathlib import Path

def restore_file(path: Path, backup: Path | None) -> None:
    if backup is not None and backup.exists():
        path.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(backup, path)
    else:
        try:
            path.unlink()
        except FileNotFoundError:
            pass

def main() -> int:
    project_dir = Path(os.environ['Z8_SM_PROJECT']).resolve()
    python_bin = os.environ.get('Z8_SM_PYTHON', sys.executable)
    sm_payload = os.environ['Z8_DEBUG_SOURCEMAPS_GRADLE_B64']
    toggle_payload = os.environ['Z8_DEBUG_SOURCEMAPS_TOGGLE_PY_B64']

    build_gradle = project_dir / 'build.gradle'
    gradlew = project_dir / 'gradlew'
    tmp_dir = project_dir / '.codex-z8-sourcemaps-tmp'
    sm_gradle = project_dir / 'gradle' / 'z8-debug-sourcemaps.gradle'
    toggle_script = project_dir / 'tools' / 'toggle_z8_debug_sourcemaps.py'

    if not project_dir.is_dir():
        print(f'Project directory not found: {project_dir}', file=sys.stderr)
        return 2
    if not build_gradle.is_file():
        print(f'build.gradle not found: {build_gradle}', file=sys.stderr)
        return 2
    if not gradlew.exists() or not os.access(gradlew, os.X_OK):
        print(f'gradlew not found or not executable: {gradlew}', file=sys.stderr)
        return 2

    had_gradle_dir = (project_dir / 'gradle').is_dir()
    had_tools_dir = (project_dir / 'tools').is_dir()
    had_sm_gradle = sm_gradle.exists()
    had_toggle_script = toggle_script.exists()

    build_backup = tmp_dir / 'build.gradle.bak'
    sm_gradle_backup = tmp_dir / 'z8-debug-sourcemaps.gradle.orig'
    toggle_backup = tmp_dir / 'toggle_z8_debug_sourcemaps.py.orig'

    tmp_dir.mkdir(parents=True, exist_ok=True)
    shutil.copy2(build_gradle, build_backup)
    if had_sm_gradle:
        shutil.copy2(sm_gradle, sm_gradle_backup)
    if had_toggle_script:
        shutil.copy2(toggle_script, toggle_backup)

    try:
        sm_gradle.parent.mkdir(parents=True, exist_ok=True)
        toggle_script.parent.mkdir(parents=True, exist_ok=True)
        sm_gradle.write_bytes(base64.b64decode(sm_payload.encode('ascii')))
        toggle_script.write_bytes(base64.b64decode(toggle_payload.encode('ascii')))
        toggle_script.chmod(toggle_script.stat().st_mode | stat.S_IXUSR)

        subprocess.run([python_bin, str(toggle_script), 'on', str(build_gradle)], cwd=str(project_dir), check=True)
        subprocess.run([str(gradlew), 'generateDebugJsSourceMap'], cwd=str(project_dir), check=True)
        return 0
    finally:
        restore_file(build_gradle, build_backup)
        restore_file(sm_gradle, sm_gradle_backup if had_sm_gradle else None)
        restore_file(toggle_script, toggle_backup if had_toggle_script else None)
        if not had_tools_dir:
            try:
                (project_dir / 'tools').rmdir()
            except OSError:
                pass
        if not had_gradle_dir:
            try:
                (project_dir / 'gradle').rmdir()
            except OSError:
                pass
        shutil.rmtree(tmp_dir, ignore_errors=True)

if __name__ == '__main__':
    raise SystemExit(main())
endef
export Z8_DEBUG_SOURCEMAPS_RUNNER_PY

help:
	@echo "Usage: make generateDebugJsSourceMap [PROJECT=/abs/or/relative/path/to/project]"
	@echo "Default PROJECT is current directory ($(CURDIR))."

generateDebugJsSourceMap:
	@Z8_SM_PROJECT="$(PROJECT_DIR)" Z8_SM_PYTHON="$(PYTHON)" $(PYTHON) -c "$$Z8_DEBUG_SOURCEMAPS_RUNNER_PY"
